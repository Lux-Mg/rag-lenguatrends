# DB local del demo (postgres+pgvector vía docker compose)
DATABASE_URL=postgresql://rag:rag123@localhost:5434/rag_lenguatrends

# DB de la tesis (origen, READ-ONLY) — solo se usa una vez por el script de ingest
SOURCE_DATABASE_URL=postgresql://lenguatrends:lenguatrends123@localhost:5432/lenguatrends_db

# Ollama (host)
OLLAMA_HOST=http://localhost:11434
